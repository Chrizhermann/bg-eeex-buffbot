}

-- ============================================================
-- Variant Picker (select spell variant for opcode 214 spells)
-- ============================================================

menu
{
	name    "BUFFBOT_VARIANTS"
	ignoreesc

	-- Dark overlay (click to close)
	text
	{
		action  "Infinity_PopMenu('BUFFBOT_VARIANTS')"
		area    0 0 99999 99999
		rectangle 1
		rectangle opacity 50
		on escape
	}

	-- Border frame
	label
	{
		name    "bbVarFrame"
		area 396 156 368 268
	}

	-- Panel background (parchment)
	label
	{
		area 420 180 320 220
		mosaic "BFBOTBG"
	}

	-- Dark mode overlay (theme-driven opacity)
	label
	{
		name    "bbDarkOverlayVar"
		rectangle 5
		rectangle opacity lua "BfBot.Theme._active.overlay"
		area 420 180 320 220
	}

	-- Title
	label
	{
		text lua "'Select Variant: ' .. buffbot_variantHeader"
		text style "bb_title"
		text color lua "BfBot.UI._T('title')"
		text align center center
		area 420 185 320 25
	}

	-- Variant list
	list
	{
		column
		{
			width 15
			label
			{
				area 2 2 32 32
				icon lua "buffbot_variantTable[rowNumber] and buffbot_variantTable[rowNumber].icon or ''"
				align center center
			}
		}

		column
		{
			width 85
			label
			{
				area 0 0 -1 34
				text lua "buffbot_variantTable[rowNumber] and buffbot_variantTable[rowNumber].name or ''"
				text style "bb_normal_parchment"
				text align left center
			}
		}

		area 430 215 290 130
		enabled     "true"
		table       "buffbot_variantTable"
		var         "buffbot_variantSelected"
		rowheight   34
		scrollbar   "GUISCRC"
	}

	-- Select button
	button
	{
		enabled "buffbot_variantSelected > 0 and buffbot_variantSelected <= #buffbot_variantTable"
		action  "BfBot.UI.SelectVariant(buffbot_variantSelected)"
		text    "Select"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 430 355 140 28
	}

	-- Cancel button
	button
	{
		action  "Infinity_PopMenu('BUFFBOT_VARIANTS')"
		text    "Cancel"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 580 355 140 28
	}
}
