-- ==========================================================
-- Preset rename sub-menu
-- ==========================================================
menu
{
	name    "BUFFBOT_RENAME"
	ignoreesc

	-- Dark overlay background (click to close)
	text
	{
		action  "Infinity_PopMenu('BUFFBOT_RENAME')"
		area    0 0 99999 99999
		rectangle 1
		rectangle opacity 50
		on escape
	}

	-- Border frame (renders behind parchment)
	label
	{
		name    "bbRenFrame"
		area 426 256 308 138
	}

	-- Small panel background (parchment)
	label
	{
		area 450 280 260 90
		mosaic "BFBOTBG"
	}

	-- Dark mode overlay (theme-driven opacity)
	label
	{
		name    "bbDarkOverlayRen"
		rectangle 5
		rectangle opacity lua "BfBot.Theme._active.overlay"
		area 450 280 260 90
	}

	-- Label
	label
	{
		text    "Rename Preset:"
		text style "bb_normal_parchment"
		text color lua "BfBot.UI._T('title')"
		text align left center
		area 460 285 240 20
	}

	-- Edit field
	edit
	{
		var     "buffbot_renameInput"
		action  "return 1"
		text style "bb_edit"
		text color lua "BfBot.UI._T('text')"
		maxlines 1
		area 460 308 240 24
	}

	-- OK button
	button
	{
		action  "BfBot.UI.ConfirmRename(); Infinity_PopMenu('BUFFBOT_RENAME')"
		text    "OK"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 460 338 80 24
	}

	-- Cancel button
	button
	{
		action  "Infinity_PopMenu('BUFFBOT_RENAME')"
		text    "Cancel"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 550 338 80 24
	}
}

-- ============================================================
-- Spell Picker (Add non-buff spells to buff list)
-- ============================================================

menu
{
	name    "BUFFBOT_SPELLPICKER"
	ignoreesc

	-- Dark overlay (click to close)
	text
	{
		action  "Infinity_PopMenu('BUFFBOT_SPELLPICKER')"
		area    0 0 99999 99999
		rectangle 1
		rectangle opacity 50
		on escape
	}

	-- Border frame (renders behind parchment)
	label
	{
		name    "bbPickFrame"
		area 356 76 448 428
	}

	-- Panel background (parchment)
	label
	{
		area 380 100 400 380
		mosaic "BFBOTBG"
	}

	-- Dark mode overlay (theme-driven opacity)
	label
	{
		name    "bbDarkOverlayPick"
		rectangle 5
		rectangle opacity lua "BfBot.Theme._active.overlay"
		area 380 100 400 380
	}

	-- Title
	label
	{
		text    "Add Spell to Buff List"
		text style "bb_title"
		text color lua "BfBot.UI._T('title')"
		text align center center
		area 380 105 400 25
	}

	-- Spell list
	list
	{
		column
		{
			width 10
			label
			{
				area 2 2 32 32
				icon lua "buffbot_pickerSpells[rowNumber] and buffbot_pickerSpells[rowNumber].icon or ''"
				align center center
			}
		}

		column
		{
			width 50
			label
			{
				area 0 0 -1 34
				text lua "buffbot_pickerSpells[rowNumber] and buffbot_pickerSpells[rowNumber].name or ''"
				text style "bb_normal_parchment"
				text align left center
			}
		}

		column
		{
			width 25
			label
			{
				area 0 0 -1 34
				text lua "buffbot_pickerSpells[rowNumber] and buffbot_pickerSpells[rowNumber].durCat or ''"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		column
		{
			width 15
			label
			{
				area 0 0 -1 34
				text lua "buffbot_pickerSpells[rowNumber] and ('x' .. buffbot_pickerSpells[rowNumber].count) or ''"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		area 390 135 360 290
		enabled     "true"
		table       "buffbot_pickerSpells"
		var         "buffbot_pickerSelected"
		rowheight   34
		scrollbar   "GUISCRC"
	}

	-- Add button
	button
	{
		enabled "BfBot.UI._PickerHasSelection()"
		action  "BfBot.UI.AddPickedSpell()"
		text    "Add to Buff List"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 390 430 180 28
	}

	-- Cancel button
	button
	{
		action  "Infinity_PopMenu('BUFFBOT_SPELLPICKER')"
		text    "Cancel"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 580 430 100 28
	}
}

-- ============================================================
