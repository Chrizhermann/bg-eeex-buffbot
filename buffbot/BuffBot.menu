---------------------
-- BuffBot UI Menu --
---------------------

-- ==========================================================
-- Companion menu for the actionbar button (pushed/popped
-- alongside WORLD_ACTIONBAR via onOpen/onClose hooks)
-- ==========================================================
menu
{
	name "BUFFBOT_ACTIONBAR"
	ignoreesc

	button
	{
		action    "BfBot.UI.Toggle()"
		tooltip lua "buffbot_btnTooltip"
		bam       "BFBOTAB"
		sequence  0
		frame lua "buffbot_btnFrame"
		scaleToClip
		area 4 4 48 48
	}

	-- Safety net tick: runs every frame, rate-limited internally to ~2s.
	-- Removes orphaned BFBTCH cheat buffs when exec engine not running.
	label
	{
		enabled "BfBot.Exec._SafetyTick()"
		area 0 0 0 0
	}
}

-- ==========================================================
-- Main configuration panel
-- ==========================================================
menu
{
	name    "BUFFBOT_MAIN"
	onopen  "BfBot.UI._OnOpen()"
	onclose "BfBot.UI._OnClose()"
	ignoreesc

	-- Full-screen click-to-close background (dark overlay)
	text
	{
		enabled "buffbot_isOpen"
		action  "BfBot.UI.Close()"
		area    0 0 99999 99999
		rectangle 1
		rectangle opacity 80
		on escape
	}

	-- Panel border (custom 9-slice leather+brass frame via EEex render hook)
	-- MUST come before bbBg so border renders behind parchment
	label
	{
		name    "bbBgFrame"
		enabled "buffbot_isOpen"
		area 340 50 540 510
	}

	-- Panel background (parchment texture, renders on top of border)
	label
	{
		name    "bbBg"
		enabled "buffbot_isOpen"
		area 340 50 540 510
		mosaic "BFBOTBG"
	}

	-- Dark mode overlay (theme-driven opacity, position synced via _Layout)
	label
	{
		name    "bbDarkOverlay"
		enabled "buffbot_isOpen"
		rectangle 5
		rectangle opacity lua "BfBot.Theme._active.overlay"
		area 340 50 540 510
	}

	-- Title
	label
	{
		name    "bbTitle"
		enabled "buffbot_isOpen"
		text lua "buffbot_title"
		text style "bb_title"
		text color lua "BfBot.UI._T('title')"
		text align center center
		area 340 55 540 30
	}

	-- Title bar drag handle (invisible — covers title area for dragging)
	handle
	{
		name       "bbDragHandle"
		actionDrag "BfBot.UI._OnDrag()"
		area 340 55 540 35
	}

	-- Resize grip visual indicator (BEFORE handle so handle gets click priority)
	label
	{
		name    "bbResizeGrip"
		enabled "buffbot_isOpen"
		text    "///"
		text style "bb_normal"
		text color lua "BfBot.UI._T('grip')"
		text align center center
		area 860 540 20 20
	}

	-- Bottom-right resize handle (ON TOP of grip visual, sized for easy grabbing)
	handle
	{
		name       "bbResizeHandle"
		actionDrag "BfBot.UI._OnResize()"
		area 800 500 80 48
	}

	-- Reset layout button (right side of title bar)
	text
	{
		name    "bbReset"
		enabled "buffbot_isOpen"
		action  "BfBot.UI._ResetLayout()"
		text    "Reset"
		text style "bb_normal"
		text color lua "BfBot.UI._T('reset')"
		text align center center
		area 820 55 50 24
	}

	-- ======================================================
	-- Character tabs (6 slots, visibility gated by party)
	-- ======================================================

	button
	{
		name    "bbC0"
		enabled "buffbot_charNames[1] ~= nil"
		action  "BfBot.UI.SetChar(0)"
		text lua "buffbot_charNames[1]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(0) and 1 or 0"
		scaleToClip
		area 350 90 80 24
	}

	button
	{
		name    "bbC1"
		enabled "buffbot_charNames[2] ~= nil"
		action  "BfBot.UI.SetChar(1)"
		text lua "buffbot_charNames[2]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(1) and 1 or 0"
		scaleToClip
		area 432 90 80 24
	}

	button
	{
		name    "bbC2"
		enabled "buffbot_charNames[3] ~= nil"
		action  "BfBot.UI.SetChar(2)"
		text lua "buffbot_charNames[3]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(2) and 1 or 0"
		scaleToClip
		area 514 90 80 24
	}

	button
	{
		name    "bbC3"
		enabled "buffbot_charNames[4] ~= nil"
		action  "BfBot.UI.SetChar(3)"
		text lua "buffbot_charNames[4]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(3) and 1 or 0"
		scaleToClip
		area 596 90 80 24
	}

	button
	{
		name    "bbC4"
		enabled "buffbot_charNames[5] ~= nil"
		action  "BfBot.UI.SetChar(4)"
		text lua "buffbot_charNames[5]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(4) and 1 or 0"
		scaleToClip
		area 678 90 80 24
	}

	button
	{
		name    "bbC5"
		enabled "buffbot_charNames[6] ~= nil"
		action  "BfBot.UI.SetChar(5)"
		text lua "buffbot_charNames[6]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsCharSelected(5) and 1 or 0"
		scaleToClip
		area 760 90 80 24
	}

	-- ======================================================
	-- Preset tabs (up to 5 dynamic) + management buttons
	-- ======================================================

	button
	{
		name    "bbP1"
		enabled "buffbot_presetNames[1] ~= nil"
		action  "BfBot.UI.SetPreset(1)"
		text lua "buffbot_presetNames[1]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(1) and 1 or 0"
		scaleToClip
		area 350 118 78 24
	}

	button
	{
		name    "bbP2"
		enabled "buffbot_presetNames[2] ~= nil"
		action  "BfBot.UI.SetPreset(2)"
		text lua "buffbot_presetNames[2]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(2) and 1 or 0"
		scaleToClip
		area 431 118 78 24
	}

	button
	{
		name    "bbP3"
		enabled "buffbot_presetNames[3] ~= nil"
		action  "BfBot.UI.SetPreset(3)"
		text lua "buffbot_presetNames[3]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(3) and 1 or 0"
		scaleToClip
		area 512 118 78 24
	}

	button
	{
		name    "bbP4"
		enabled "buffbot_presetNames[4] ~= nil"
		action  "BfBot.UI.SetPreset(4)"
		text lua "buffbot_presetNames[4]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(4) and 1 or 0"
		scaleToClip
		area 593 118 78 24
	}

	button
	{
		name    "bbP5"
		enabled "buffbot_presetNames[5] ~= nil"
		action  "BfBot.UI.SetPreset(5)"
		text lua "buffbot_presetNames[5]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(5) and 1 or 0"
		scaleToClip
		area 674 118 78 24
	}

	button
	{
		name    "bbP6"
		enabled "buffbot_presetNames[6] ~= nil"
		action  "BfBot.UI.SetPreset(6)"
		text lua "buffbot_presetNames[6]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(6) and 1 or 0"
		scaleToClip
		area 674 118 78 24
	}

	button
	{
		name    "bbP7"
		enabled "buffbot_presetNames[7] ~= nil"
		action  "BfBot.UI.SetPreset(7)"
		text lua "buffbot_presetNames[7]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(7) and 1 or 0"
		scaleToClip
		area 674 118 78 24
	}

	button
	{
		name    "bbP8"
		enabled "buffbot_presetNames[8] ~= nil"
		action  "BfBot.UI.SetPreset(8)"
		text lua "buffbot_presetNames[8]"
		text style "bb_button"
		bam     "GUIOSTUL"
		frame lua "BfBot.UI._IsPresetSelected(8) and 1 or 0"
		scaleToClip
		area 674 118 78 24
	}

	-- Rename preset button
	button
	{
		name    "bbRen"
		enabled "buffbot_isOpen"
		action  "BfBot.UI.OpenRename()"
		text    "Rename"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 758 118 56 24
	}

	-- New preset button
	button
	{
		name    "bbNew"
		enabled "BfBot.UI._CanCreatePreset()"
		action  "BfBot.UI.CreateNewPreset()"
		text    "New"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 818 118 50 24
	}

	-- ======================================================
	-- Spell list (click row to toggle enable/disable)
	-- Columns MUST come before properties (parser quirk).
	-- Only label elements inside columns (no buttons).
	-- ======================================================

	list
	{
		-- Column 1: Enable/disable checkbox (text-based)
		column
		{
			width 8
			label
			{
				area 0 0 -1 36
				text lua "BfBot.UI._CheckboxText(rowNumber)"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		-- Column 2: Spell icon
		column
		{
			width 8
			label
			{
				area 2 2 32 32
				icon lua "buffbot_spellTable[rowNumber].icon"
				count lua "buffbot_spellTable[rowNumber].count"
				greyscale lua "buffbot_spellTable[rowNumber].castable == 0"
				align center center
			}
		}

		-- Column 3: Spell name
		column
		{
			width 28
			label
			{
				area 0 0 -1 36
				text lua "buffbot_spellTable[rowNumber].name"
				text style "bb_normal_parchment"
				text align left center
				text color lua "BfBot.UI._SpellNameColor(rowNumber)"
			}
		}

		-- Column 4: Duration
		column
		{
			width 12
			label
			{
				area 0 0 -1 36
				text lua "buffbot_spellTable[rowNumber] and buffbot_spellTable[rowNumber].durText or ''"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		-- Column 5: Memorized count
		column
		{
			width 12
			label
			{
				area 0 0 -1 36
				text lua "buffbot_spellTable[rowNumber].countText"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		-- Column 6: Target display
		column
		{
			width 26
			label
			{
				area 0 0 -1 36
				text lua "buffbot_spellTable[rowNumber].targetText"
				text style "bb_normal_parchment"
				text align center center
			}
		}

		-- Column 7: Lock toggle ([L] / [ ])
		column
		{
			width 6
			label
			{
				area 0 0 -1 36
				text lua "BfBot.UI._LockText(rowNumber)"
				text style "bb_normal_parchment"
				text align center center
				text color lua "BfBot.UI._LockColor(rowNumber)"
			}
		}

		area 350 148 520 250
		name    "bbList"
		action      "BfBot.UI._UpdateVariantState(); if cellNumber <= 2 then BfBot.UI.ToggleSpell(buffbot_selectedRow) elseif cellNumber == 7 then BfBot.UI.ToggleLock(buffbot_selectedRow) end"
		enabled     "buffbot_isOpen"
		table       "buffbot_spellTable"
		var         "buffbot_selectedRow"
		rowheight   36
		scrollbar   "GUISCRC"
	}

	-- ======================================================
	-- Spell Override buttons (Add non-buff / Remove false positive)
	-- ======================================================

	-- Add non-buff spell to buff list
	button
	{
		name    "bbAdd"
		enabled "buffbot_isOpen"
		action  "BfBot.UI.OpenSpellPicker()"
		text    "Add Spell"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 350 402 120 28
	}

	-- Remove selected spell from buff list (exclude override)
	button
	{
		name    "bbRmv"
		enabled "BfBot.UI._HasSelection()"
		action  "BfBot.UI.ExcludeSelected()"
		text    "Remove"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 476 402 120 28
	}

	-- Export current character's config
	button
	{
		name    "bbExp"
		enabled "buffbot_isOpen and not BfBot._noIO"
		action  "BfBot.UI.ExportConfig()"
		text    "Export"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 610 402 90 28
	}

	-- Import config from file
	button
	{
		name    "bbImp"
		enabled "buffbot_isOpen and not BfBot._noIO"
		action  "BfBot.UI.OpenImportPicker()"
		text    "Import"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 706 402 90 28
	}

	-- ======================================================
	-- Selected spell actions (Toggle + Change Target)
	-- Normal layout: visible when selected spell has NO variants
	-- ======================================================

	-- Toggle enable/disable for selected spell
	button
	{
		name    "bbTog"
		enabled "BfBot.UI._HasSelection() and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.ToggleSelected()"
		text lua "BfBot.UI._ToggleBtnText()"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 350 434 120 28
	}

	-- Change target for selected spell
	button
	{
		name    "bbTgt"
		enabled "BfBot.UI._HasSelection() and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.OpenTargetsForSelected()"
		text lua "BfBot.UI._TargetBtnText()"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 476 434 160 28
	}

	-- Move selected spell up in cast order
	button
	{
		name    "bbUp"
		enabled "BfBot.UI._CanMoveUp() and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.MoveSpellUp()"
		text    "Up"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 642 434 48 28
	}

	-- Move selected spell down in cast order
	button
	{
		name    "bbDn"
		enabled "BfBot.UI._CanMoveDown() and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.MoveSpellDown()"
		text    "Down"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 694 434 48 28
	}

	-- Sort preset by duration (longest first)
	button
	{
		name    "bbSort"
		enabled "buffbot_isOpen and #buffbot_spellTable > 1 and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.SortByDuration()"
		text    "Sort"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 748 434 48 28
	}

	-- Delete current preset
	button
	{
		name    "bbDel"
		enabled "BfBot.UI._CanDeletePreset() and buffbot_selectedHasVariants ~= 1"
		action  "BfBot.UI.DeleteCurrentPreset()"
		text    "Delete Preset"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 800 434 130 28
	}

	-- ======================================================
	-- Variant spell action buttons (squeezed layout)
	-- Visible only when selected spell HAS variants
	-- ======================================================

	-- Toggle (variant layout)
	button
	{
		name    "bbVTog"
		enabled "BfBot.UI._HasSelection() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.ToggleSelected()"
		text lua "BfBot.UI._ToggleBtnText()"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 350 434 90 28
	}

	-- Target (variant layout)
	button
	{
		name    "bbVTgt"
		enabled "BfBot.UI._HasSelection() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.OpenTargetsForSelected()"
		text lua "BfBot.UI._TargetBtnText()"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 444 434 110 28
	}

	-- Variant picker button
	button
	{
		name    "bbVVar"
		enabled "BfBot.UI._HasSelection() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.OpenVariantsForSelected()"
		text lua "BfBot.UI._VariantBtnText()"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 558 434 110 28
	}

	-- Up (variant layout)
	button
	{
		name    "bbVUp"
		enabled "BfBot.UI._CanMoveUp() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.MoveSpellUp()"
		text    "Up"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 672 434 44 28
	}

	-- Down (variant layout)
	button
	{
		name    "bbVDn"
		enabled "BfBot.UI._CanMoveDown() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.MoveSpellDown()"
		text    "Down"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 720 434 44 28
	}

	-- Sort (variant layout)
	button
	{
		name    "bbVSort"
		enabled "buffbot_isOpen and #buffbot_spellTable > 1 and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.SortByDuration()"
		text    "Sort"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 768 434 44 28
	}

	-- Delete Preset (variant layout)
	button
	{
		name    "bbVDel"
		enabled "BfBot.UI._CanDeletePreset() and buffbot_selectedHasVariants == 1"
		action  "BfBot.UI.DeleteCurrentPreset()"
		text    "Del Preset"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 816 434 102 28
	}

	-- ======================================================
	-- Action buttons + status
	-- ======================================================

	-- Cast All button
	button
	{
		name    "bbCast"
		enabled "buffbot_isOpen"
		clickable lua "BfBot.UI._CanCast()"
		action  "BfBot.UI.Cast()"
		text lua "buffbot_castLabel"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 350 468 100 28
	}

	-- Cast Character button
	button
	{
		name    "bbCastChar"
		enabled "buffbot_isOpen"
		clickable lua "BfBot.UI._CanCast()"
		action  "BfBot.UI.CastCharacter()"
		text lua "buffbot_castCharLabel"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 454 468 140 28
	}

	-- Stop button (only visible when running)
	button
	{
		name    "bbStop"
		enabled "BfBot.UI._IsRunning()"
		action  "BfBot.UI.Stop()"
		text    "Stop"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 536 468 80 28
	}

	-- Quick Cast cycling button (text element: supports both action + text color lua)
	text
	{
		name    "bbQC"
		enabled "buffbot_isOpen and not BfBot._noIO"
		action  "BfBot.UI.CycleQuickCast()"
		text lua "BfBot.UI._QuickCastLabel()"
		text style "bb_normal"
		text color lua "BfBot.UI._QuickCastColor()"
		text align center center
		tooltip lua "BfBot.UI._QuickCastTooltip()"
		rectangle 5
		rectangle opacity 160
		area 622 468 162 28
	}

	-- Close button
	button
	{
		name    "bbClose"
		enabled "buffbot_isOpen"
		action  "BfBot.UI.Close()"
		text    "Close"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 790 468 80 28
	}

	-- Status line
	label
	{
		name    "bbStatus"
		enabled "buffbot_isOpen"
		text lua "buffbot_status"
		text style "bb_normal_parchment"
		text align left center
		area 350 500 520 24
	}
}

-- ==========================================================
-- Target picker sub-menu — ordered priority list
-- ==========================================================
menu
{
	name    "BUFFBOT_TARGETS"
	ignoreesc

	-- Dark overlay background (click to close = cancel)
	text
	{
		action  "Infinity_PopMenu('BUFFBOT_TARGETS')"
		area    0 0 99999 99999
		rectangle 1
		rectangle opacity 50
		on escape
	}

	-- Border frame
	label
	{
		name    "bbTgtFrame"
		area 450 120 260 450
	}

	-- Panel background (parchment)
	label
	{
		area 474 144 212 402
		mosaic "BFBOTBG"
	}

	-- Dark mode overlay (theme-driven opacity)
	label
	{
		name    "bbDarkOverlayTgt"
		rectangle 5
		rectangle opacity lua "BfBot.Theme._active.overlay"
		area 474 144 212 402
	}

	-- Header: spell name
	label
	{
		text lua "buffbot_targetHeader"
		text style "bb_normal_parchment"
		text align left center
		text color lua "BfBot.UI._T('headerSub')"
		area 479 149 202 20
	}

	-- Lock state text (Self-only / Party-wide)
	label
	{
		enabled "buffbot_targetLocked == 1"
		text lua "buffbot_targetLockText"
		text style "bb_normal_parchment"
		text align center center
		text color lua "BfBot.UI._T('lockText')"
		area 479 174 202 20
	}

	-- "Self" button
	button
	{
		enabled "buffbot_targetLocked == 0"
		action  "BfBot.UI.PickerSelf()"
		text    "Self"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 479 199 95 26
	}

	-- "All Party" button
	button
	{
		enabled "buffbot_targetLocked == 0"
		action  "BfBot.UI.PickerAllParty()"
		text    "All Party"
		text style "bb_button"
		bam     "GUIOSTUL"
		scaleToClip
		area 581 199 95 26
	}

	-- Row 1: checkbox (toggle) + name (select)
	button
	{
		enabled "buffbot_targetLocked == 0 and buffbot_pickerOrder[1] ~= nil"
